---
import BaseLayout from "../layouts/BaseLayout.astro";

const positions = [
  {
    title: "Remote Sales Rep (Closer)",
    items: [
      "Inbound/Outbound Sales Representative",
      "1+ Years of sales experience required",
      "10% Commissions",
    ],
    tags: ["Remote", "Full-Time"],
  },
  {
    title: "SDR / Setter",
    items: [
      "Outbound SDR/Appointment Setter to Leads Generated By Our Clients",
      "Experience Preferred",
      "2-5% Commissions",
    ],
    tags: ["Remote", "Full-Time"],
  },
  {
    title: "Sales Manager",
    items: [
      "Manage and Scale High-Performing Sales Teams",
      "Proven Track Record in High-Ticket Sales Leadership",
      "Base + Override Commissions",
    ],
    tags: ["Remote", "Full-Time"],
  },
];
---

<BaseLayout
  title="Open Positions — Careers at SalesAtScale.io"
  description="Join SalesAtScale.io as a closer, setter, or sales manager. Remote positions with commission-based compensation for top sales talent."
>
  <section class="bg-base min-h-screen py-20 px-6 sm:px-12 lg:px-24 flex justify-center">
    <div class="w-full max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 lg:gap-24 items-start pt-16">

      <!-- LEFT: Sticky Header -->
      <div class="w-full lg:w-1/3 lg:sticky lg:top-24 flex flex-col">
        <h1 class="font-chivo font-black text-heading text-[40px] md:text-[50px] leading-[1.05] tracking-tight uppercase mb-6 drop-shadow-md">
          Open Positions
        </h1>
        <p class="font-chivo font-medium text-body text-[17px] leading-relaxed">
          Whether you are a seasoned sales professional or an aspiring talent, join us in redefining what good sales looks like. Explore our current openings and take the next step towards a rewarding career with us.
        </p>
      </div>

      <!-- RIGHT: Position Cards -->
      <div class="w-full lg:w-2/3 flex flex-col gap-8">
        {positions.map((pos) => (
          <div class="group relative w-full bg-card rounded-2xl p-8 border border-card-border transition-all duration-400 hover:-translate-y-1 hover:border-blue/50 hover:shadow-[0_20px_40px_rgba(0,0,0,0.5)] flex flex-col">
            <div class="absolute inset-0 rounded-2xl bg-[radial-gradient(circle_at_top_right,rgba(0,59,224,0.05),transparent_60%)] opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

            <div class="relative z-10">
              <h2 class="font-chivo font-bold text-heading text-2xl mb-6">{pos.title}</h2>
              <ul class="flex flex-col gap-4 mb-8">
                {pos.items.map((item) => (
                  <li class="flex items-start gap-3 font-chivo font-medium text-body text-[16px]">
                    <svg class="w-5 h-5 text-blue shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="square" stroke-linejoin="miter">
                      <rect x="2" y="2" width="20" height="20" fill="rgba(0, 59, 224, 0.1)" stroke="none"></rect>
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <!-- Footer: Tags & CTA -->
            <div class="mt-auto pt-6 border-t border-card-border/50 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 relative z-10">
              <div class="flex flex-wrap items-center gap-3">
                {pos.tags.map((tag) => (
                  <span class="flex items-center gap-2 text-sm font-bold bg-base px-3 py-1.5 rounded-md border border-card-border" style="color:#F8FAFC;">
                    {tag === "Remote" ? (
                      <svg class="w-4 h-4 text-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                    ) : (
                      <svg class="w-4 h-4 text-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
                    )}
                    {tag}
                  </span>
                ))}
              </div>
              <a href="/apply/" class="w-full sm:w-auto px-6 py-3 bg-blue text-white font-chivo font-bold tracking-wide uppercase text-sm rounded-md shadow-btn-glow hover:bg-blue-hover hover:shadow-btn-glow-hover hover:-translate-y-0.5 transition-all text-center">
                Apply Now
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>
