---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Done-For-You Sales Teams — SalesAtScale.io"
  description="We source, vet, train, and manage top 1% closers for your business on a purely performance basis. Stop wasting marketing dollars on unclosed leads."
>

  <!-- ========== HERO SECTION ========== -->
  <section class="relative bg-base pt-28 pb-20 overflow-hidden">
    <!-- Tech Grid Background -->
    <div class="absolute inset-0 bg-grid-service pointer-events-none"></div>
    <!-- Ambient Glow -->
    <div class="absolute -top-[20%] left-1/2 -translate-x-1/2 w-[70%] h-[60%] rounded-full bg-blue blur-[160px] opacity-10 pointer-events-none"></div>
    <!-- Noise -->
    <div class="absolute inset-0 bg-noise pointer-events-none"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
      <!-- Eyebrow Pill -->
      <div class="inline-flex items-center gap-2.5 bg-surface border border-card-border rounded-full px-5 py-2 mb-8">
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-blue"></span>
        </span>
        <span class="font-chivo text-xs font-semibold tracking-widest uppercase" style="color:#94A3B8;">Bolt-on sales infrastructure for high-ticket businesses</span>
      </div>

      <!-- H1 -->
      <h1 class="font-chivo font-black text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight mb-6" style="color:#F8FAFC;">
        The Exact Infrastructure We Use To Build &amp; Scale <em class="text-blue not-italic italic">7-Figure Sales Teams</em>
      </h1>

      <!-- Subheadline -->
      <p class="font-jakarta text-base md:text-lg leading-relaxed max-w-3xl mx-auto mb-12" style="color:#94A3B8;">
        Stop wasting marketing dollars on unclosed leads. We source, vet, train, and manage top 1% closers for you on a purely performance basis.
      </p>

      <!-- VSL Video Player -->
      <div class="relative max-w-3xl mx-auto">
        <!-- Glow Effect -->
        <div class="absolute -inset-4 bg-blue/15 rounded-3xl blur-2xl -z-10"></div>
        <div class="relative rounded-2xl overflow-hidden bg-card border border-card-border aspect-video shadow-card">
          <img
            src="https://placehold.co/960x540/1E293B/003be0?text=VSL+Video"
            alt="Done-For-You Sales Teams overview video"
            class="w-full h-full object-cover"
            width="960"
            height="540"
            loading="eager"
          />
          <div class="absolute inset-0 flex items-center justify-center">
            <button class="w-18 h-18 md:w-20 md:h-20 bg-blue rounded-full flex items-center justify-center shadow-btn-glow hover:bg-blue-hover hover:scale-110 transition-all duration-300 group" aria-label="Play video">
              <svg class="w-7 h-7 md:w-8 md:h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== AUTHORITY BANNER ========== -->
  <section class="bg-base border-y border-card-border py-8 overflow-hidden">
    <p class="text-center text-xs font-semibold tracking-widest uppercase mb-6" style="color:#94A3B8;">Trusted by industry leaders</p>
    <div class="w-full overflow-hidden mask-edges marquee-container">
      <div class="flex w-[200%] animate-scroll items-center">
        <div class="flex w-1/2 justify-around items-center px-4 gap-12 sm:gap-20">
          <img src="https://placehold.co/200x80/transparent/white?text=Logo+1" alt="Client 1" class="logo-image" width="200" height="80" loading="lazy" />
          <img src="https://placehold.co/200x80/transparent/white?text=Logo+2" alt="Client 2" class="logo-image" width="200" height="80" loading="lazy" />
          <img src="https://placehold.co/200x80/transparent/white?text=Logo+3" alt="Client 3" class="logo-image" width="200" height="80" loading="lazy" />
          <img src="https://placehold.co/200x80/transparent/white?text=Logo+4" alt="Client 4" class="logo-image" width="200" height="80" loading="lazy" />
          <img src="https://placehold.co/200x80/transparent/white?text=Logo+5" alt="Client 5" class="logo-image" width="200" height="80" loading="lazy" />
          <img src="https://placehold.co/200x80/transparent/white?text=Logo+6" alt="Client 6" class="logo-image" width="200" height="80" loading="lazy" />
        </div>
        <div class="flex w-1/2 justify-around items-center px-4 gap-12 sm:gap-20">
          <img src="https://placehold.co/200x80/transparent/white?text=Logo+1" alt="Client 1" class="logo-image" width="200" height="80" loading="lazy" />
          <img src="https://placehold.co/200x80/transparent/white?text=Logo+2" alt="Client 2" class="logo-image" width="200" height="80" loading="lazy" />
          <img src="https://placehold.co/200x80/transparent/white?text=Logo+3" alt="Client 3" class="logo-image" width="200" height="80" loading="lazy" />
          <img src="https://placehold.co/200x80/transparent/white?text=Logo+4" alt="Client 4" class="logo-image" width="200" height="80" loading="lazy" />
          <img src="https://placehold.co/200x80/transparent/white?text=Logo+5" alt="Client 5" class="logo-image" width="200" height="80" loading="lazy" />
          <img src="https://placehold.co/200x80/transparent/white?text=Logo+6" alt="Client 6" class="logo-image" width="200" height="80" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TYPEFORM EMBED SECTION ========== -->
  <section id="apply" class="bg-surface py-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="font-chivo font-bold tracking-[0.2em] uppercase text-sm mb-4 block text-blue">Apply Now</span>
        <h2 class="font-chivo font-black text-3xl md:text-4xl tracking-tight uppercase mb-4" style="color:#F8FAFC;">
          See If You Qualify
        </h2>
        <p class="font-jakarta text-base leading-relaxed max-w-2xl mx-auto" style="color:#94A3B8;">
          Fill out the short application below and our team will be in touch within 24 hours.
        </p>
      </div>
      <div class="relative rounded-2xl bg-card border border-card-border p-8 md:p-12 min-h-[500px]">
        <!-- Loading Skeleton -->
        <div id="typeform-skeleton" class="absolute inset-0 flex items-center justify-center">
          <div class="flex flex-col items-center gap-4">
            <svg class="animate-spin h-8 w-8 text-blue" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span class="text-sm font-chivo" style="color:#94A3B8;">Loading application...</span>
          </div>
        </div>
        <!-- Typeform Embed Placeholder -->
        <div data-tf-live="YOUR_TYPEFORM_ID" class="w-full min-h-[600px] relative z-10"></div>
      </div>
    </div>
  </section>

  <!-- ========== WHO WE WORK WITH ========== -->
  <section class="bg-base py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-grid-service pointer-events-none"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-6">
      <!-- Header -->
      <div class="text-center mb-16">
        <span class="font-chivo font-bold tracking-[0.2em] uppercase text-sm mb-4 block text-blue">Ideal Clients</span>
        <h2 class="font-chivo font-black text-3xl md:text-[44px] leading-[1.1] tracking-tight uppercase mb-4" style="color:#F8FAFC;">
          We Work With <span class="text-blue">2 Types Of Businesses</span>
        </h2>
      </div>

      <!-- 2 Cards -->
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- Card 1: Underperforming Sales Team -->
        <div class="group rounded-2xl bg-card border border-card-border p-8 md:p-10 hover:-translate-y-1 transition-all duration-300 hover:shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
          <!-- Icon -->
          <div class="mb-6 relative w-16 h-16 flex items-center justify-center">
            <div class="absolute inset-0 bg-blue/20 rounded-xl blur-lg group-hover:bg-blue/30 transition-colors"></div>
            <svg class="relative w-10 h-10 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="3" width="20" height="14" rx="2" />
              <path d="M8 21h8M12 17v4" />
              <path d="M7 13l3-3 2 2 5-5" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M17 7v3h-3" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h3 class="font-chivo font-black text-xl md:text-2xl uppercase tracking-tight mb-3" style="color:#F8FAFC;">Underperforming Sales Team</h3>
          <p class="font-jakarta text-base leading-relaxed" style="color:#94A3B8;">
            You have leads flowing in but your team can't convert. Broken scripts, no follow-up systems, inconsistent performance, and reps quitting every other month. You know there's revenue on the table — you just can't capture it.
          </p>
        </div>

        <!-- Card 2: New Sales Team Builder -->
        <div class="group rounded-2xl bg-card border border-card-border p-8 md:p-10 hover:-translate-y-1 transition-all duration-300 hover:shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
          <!-- Icon -->
          <div class="mb-6 relative w-16 h-16 flex items-center justify-center">
            <div class="absolute inset-0 bg-blue/20 rounded-xl blur-lg group-hover:bg-blue/30 transition-colors"></div>
            <svg class="relative w-10 h-10 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M3 21h18M5 21V7l8-4v18M13 21V5l6 3v13" />
              <path d="M9 9h1M9 12h1M9 15h1" stroke-linecap="round" />
              <path d="M15 11l2 3 2-5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h3 class="font-chivo font-black text-xl md:text-2xl uppercase tracking-tight mb-3" style="color:#F8FAFC;">New Sales Team Builder</h3>
          <p class="font-jakarta text-base leading-relaxed" style="color:#94A3B8;">
            You've been the sole closer in your business and it's working — but you've hit a ceiling. You need to scale from founder-led sales to a fully managed sales team without losing quality or burning through bad hires.
          </p>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center">
        <a href="#apply" class="group inline-flex items-center gap-2 bg-blue hover:bg-blue-hover text-white font-chivo font-bold text-sm md:text-base tracking-[0.08em] uppercase px-12 py-4 rounded-md transition-all duration-300 shadow-btn-glow hover:shadow-btn-glow-hover hover:-translate-y-0.5">
          Get Started Now
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== THE FRAMEWORK / 4 PHASES ========== -->
  <section class="bg-surface py-24 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Header -->
      <div class="text-center mb-20">
        <span class="font-chivo font-bold tracking-[0.2em] uppercase text-sm mb-4 block text-blue">The Framework</span>
        <h2 class="font-chivo font-black text-3xl md:text-[44px] leading-[1.1] tracking-tight uppercase" style="color:#F8FAFC;">
          The 4 Systems We Deploy <br class="hidden md:block"/>To Scale Your Revenue
        </h2>
      </div>

      <!-- Phases Container -->
      <div class="relative">
        <!-- Vertical Connecting Line (desktop) -->
        <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px -translate-x-1/2" style="background:linear-gradient(to bottom, #003be0 0%, rgba(0,59,224,0.4) 60%, transparent 100%);"></div>

        <!-- Phase 01: MIND (Alignment) -->
        <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 items-center mb-20">
          <!-- Connector Dot -->
          <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10 w-5 h-5 rounded-full bg-blue shadow-btn-glow items-center justify-center">
            <div class="w-2 h-2 rounded-full bg-white"></div>
          </div>
          <!-- Text (left) -->
          <div class="md:pr-12">
            <span class="font-chivo font-bold tracking-[0.2em] uppercase text-xs text-blue mb-2 block">Phase 01</span>
            <h3 class="font-chivo font-black text-2xl md:text-3xl uppercase tracking-tight mb-4" style="color:#F8FAFC;">MIND (Alignment)</h3>
            <p class="font-jakarta text-base leading-relaxed mb-6" style="color:#94A3B8;">
              Before we touch your sales process, we audit your unit economics, offer structure, and market positioning. We align on revenue targets, cash-collected goals, and the exact sales model your business needs to scale predictably.
            </p>
            <div class="rounded-lg border border-blue/30 bg-blue/5 p-4">
              <span class="font-chivo font-bold text-xs tracking-widest uppercase text-blue block mb-1">The Goal</span>
              <p class="font-jakarta text-sm leading-relaxed" style="color:#94A3B8;">Crystal-clear revenue targets and a validated offer that your sales team can confidently close.</p>
            </div>
          </div>
          <!-- Icon (right) -->
          <div class="flex justify-center md:pl-12 order-first md:order-last">
            <div class="relative w-32 h-32 flex items-center justify-center">
              <div class="absolute inset-0 bg-blue/10 rounded-2xl blur-2xl"></div>
              <svg class="relative w-20 h-20 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
                <path d="M12 2a7 7 0 017 7c0 3-2 5.5-4 7l-1 1.5a2 2 0 01-4 0L9 16c-2-1.5-4-4-4-7a7 7 0 017-7z" />
                <circle cx="12" cy="9" r="2" />
                <path d="M9 22h6" stroke-linecap="round" />
              </svg>
            </div>
          </div>
        </div>

        <!-- Phase 02: Systems Buildout -->
        <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 items-center mb-20">
          <!-- Connector Dot -->
          <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10 w-5 h-5 rounded-full bg-blue shadow-btn-glow items-center justify-center">
            <div class="w-2 h-2 rounded-full bg-white"></div>
          </div>
          <!-- Icon (left) -->
          <div class="flex justify-center md:pr-12">
            <div class="relative w-32 h-32 flex items-center justify-center">
              <div class="absolute inset-0 bg-blue/10 rounded-2xl blur-2xl"></div>
              <svg class="relative w-20 h-20 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
                <circle cx="12" cy="12" r="3" />
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke-linecap="round" />
                <path d="M14.5 9.5l2-2M9.5 14.5l-2 2" stroke-linecap="round" />
              </svg>
            </div>
          </div>
          <!-- Text (right) -->
          <div class="md:pl-12">
            <span class="font-chivo font-bold tracking-[0.2em] uppercase text-xs text-blue mb-2 block">Phase 02</span>
            <h3 class="font-chivo font-black text-2xl md:text-3xl uppercase tracking-tight mb-4" style="color:#F8FAFC;">Systems Buildout</h3>
            <p class="font-jakarta text-base leading-relaxed mb-6" style="color:#94A3B8;">
              We build the entire back-end machine: CRM pipelines, automated follow-up sequences, call scripts, objection-handling frameworks, and SOPs for every stage of your sales process. Nothing is left to chance.
            </p>
            <div class="rounded-lg border border-blue/30 bg-blue/5 p-4">
              <span class="font-chivo font-bold text-xs tracking-widest uppercase text-blue block mb-1">The Goal</span>
              <p class="font-jakarta text-sm leading-relaxed" style="color:#94A3B8;">A turnkey sales machine with documented processes that any A-player can plug into and start closing.</p>
            </div>
          </div>
        </div>

        <!-- Phase 03: Installing Setters & Closers -->
        <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 items-center mb-20">
          <!-- Connector Dot -->
          <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10 w-5 h-5 rounded-full bg-blue shadow-btn-glow items-center justify-center">
            <div class="w-2 h-2 rounded-full bg-white"></div>
          </div>
          <!-- Text (left) -->
          <div class="md:pr-12">
            <span class="font-chivo font-bold tracking-[0.2em] uppercase text-xs text-blue mb-2 block">Phase 03</span>
            <h3 class="font-chivo font-black text-2xl md:text-3xl uppercase tracking-tight mb-4" style="color:#F8FAFC;">Installing Setters &amp; Closers</h3>
            <p class="font-jakarta text-base leading-relaxed mb-6" style="color:#94A3B8;">
              We source, vet, and place top 1% sales talent into your business. Every rep goes through our proprietary screening process, role-play evaluations, and onboarding training before they ever touch a lead.
            </p>
            <div class="rounded-lg border border-blue/30 bg-blue/5 p-4">
              <span class="font-chivo font-bold text-xs tracking-widest uppercase text-blue block mb-1">The Goal</span>
              <p class="font-jakarta text-sm leading-relaxed" style="color:#94A3B8;">Battle-tested closers installed and trained on your specific offer, ready to convert on day one.</p>
            </div>
          </div>
          <!-- Icon (right) -->
          <div class="flex justify-center md:pl-12 order-first md:order-last">
            <div class="relative w-32 h-32 flex items-center justify-center">
              <div class="absolute inset-0 bg-blue/10 rounded-2xl blur-2xl"></div>
              <svg class="relative w-20 h-20 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
                <circle cx="9" cy="7" r="3" />
                <circle cx="17" cy="7" r="3" />
                <path d="M5 21v-2a4 4 0 014-4h2" />
                <path d="M13 21v-2a4 4 0 014-4h0" />
                <path d="M12 14l2 2 4-4" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" />
              </svg>
            </div>
          </div>
        </div>

        <!-- Phase 04: Revenue Orchestration -->
        <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 items-center">
          <!-- Connector Dot -->
          <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-10 w-5 h-5 rounded-full bg-blue shadow-btn-glow items-center justify-center">
            <div class="w-2 h-2 rounded-full bg-white"></div>
          </div>
          <!-- Icon (left) -->
          <div class="flex justify-center md:pr-12">
            <div class="relative w-32 h-32 flex items-center justify-center">
              <div class="absolute inset-0 bg-blue/10 rounded-2xl blur-2xl"></div>
              <svg class="relative w-20 h-20 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
                <path d="M3 3v18h18" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M7 16l4-5 4 3 5-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" />
                <circle cx="20" cy="7" r="2" fill="currentColor" stroke="none" />
              </svg>
            </div>
          </div>
          <!-- Text (right) -->
          <div class="md:pl-12">
            <span class="font-chivo font-bold tracking-[0.2em] uppercase text-xs text-blue mb-2 block">Phase 04</span>
            <h3 class="font-chivo font-black text-2xl md:text-3xl uppercase tracking-tight mb-4" style="color:#F8FAFC;">Revenue Orchestration</h3>
            <p class="font-jakarta text-base leading-relaxed mb-6" style="color:#94A3B8;">
              We act as your fractional VP of Sales — running daily huddles, reviewing call recordings, coaching reps, and optimizing every metric. Pipeline velocity, conversion rates, and cash collected are monitored in real time.
            </p>
            <div class="rounded-lg border border-blue/30 bg-blue/5 p-4">
              <span class="font-chivo font-bold text-xs tracking-widest uppercase text-blue block mb-1">The Goal</span>
              <p class="font-jakarta text-sm leading-relaxed" style="color:#94A3B8;">A self-improving sales engine that scales revenue month-over-month without you managing a single rep.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center mt-20">
        <a href="#apply" class="group inline-flex items-center gap-2 bg-blue hover:bg-blue-hover text-white font-chivo font-bold text-sm md:text-base tracking-[0.08em] uppercase px-12 py-4 rounded-md transition-all duration-300 shadow-btn-glow hover:shadow-btn-glow-hover hover:-translate-y-0.5">
          Apply For This Infrastructure
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== WALL OF PROOF ========== -->
  <section class="bg-base py-24 relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Header -->
      <div class="text-center mb-16">
        <span class="font-chivo font-bold tracking-[0.2em] uppercase text-sm mb-4 block text-blue">The Receipts</span>
        <h2 class="font-chivo font-black text-3xl md:text-[44px] leading-[1.1] tracking-tight uppercase" style="color:#F8FAFC;">
          Undeniable Proof
        </h2>
      </div>

      <!-- Masonry Grid -->
      <div class="relative">
        <div class="columns-1 md:columns-2 gap-6 space-y-6">
          <!-- Proof Item 1 -->
          <div class="break-inside-avoid rounded-2xl bg-card border border-card-border p-6 overflow-hidden">
            <img src="https://placehold.co/600x400/1E293B/003be0?text=Proof+1" alt="Results proof 1" class="w-full rounded-lg mb-4" width="600" height="400" loading="lazy" />
            <p class="font-chivo font-bold text-sm uppercase text-blue">+$247k in 60 Days</p>
          </div>
          <!-- Proof Item 2 -->
          <div class="break-inside-avoid rounded-2xl bg-card border border-card-border p-6 overflow-hidden">
            <img src="https://placehold.co/600x300/1E293B/003be0?text=Proof+2" alt="Results proof 2" class="w-full rounded-lg mb-4" width="600" height="300" loading="lazy" />
            <p class="font-chivo font-bold text-sm uppercase text-blue">Close Rate: 12% → 31%</p>
          </div>
          <!-- Proof Item 3 -->
          <div class="break-inside-avoid rounded-2xl bg-card border border-card-border p-6 overflow-hidden">
            <img src="https://placehold.co/600x500/1E293B/003be0?text=Proof+3" alt="Results proof 3" class="w-full rounded-lg mb-4" width="600" height="500" loading="lazy" />
            <p class="font-chivo font-bold text-sm uppercase text-blue">Scaled to 8-Figure Run Rate</p>
          </div>
