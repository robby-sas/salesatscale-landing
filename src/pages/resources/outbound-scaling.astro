---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="SDR Outbound Scaling Framework — Free SOP | SalesAtScale.io"
  description="Access our full outbound scaling documentation. Learn the exact cadence, follow-up strategies, and daily KPI tracking sheets."
>
  <!-- Back Link + Hero -->
  <section class="w-full max-w-6xl mx-auto px-6 pt-28 pb-8">
    <a href="/resources/" class="inline-flex items-center gap-1 font-chivo font-medium text-sm text-blue hover:text-blue-light transition-colors mb-10 no-underline">
      &larr; Back to All SOPs
    </a>

    <!-- Hero Headline -->
    <div class="text-center max-w-4xl mx-auto mb-16">
      <h1 class="font-chivo font-black text-4xl md:text-5xl lg:text-[52px] leading-[1.1] tracking-tight" style="color:#F8FAFC;">
        Access The Complete "Outbound Scaling" SOP & Start Booking <span class="text-blue">100+ Qualified Calls/mo</span> For FREE
      </h1>
    </div>
  </section>

  <!-- Two-Column: Document Spread + Opt-in Form -->
  <section class="w-full max-w-6xl mx-auto px-6 pb-24">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-center">

      <!-- Left: Staggered Document Spread -->
      <div class="w-full lg:w-1/2 flex items-center justify-center">
        <div class="relative w-full aspect-square md:aspect-[4/3] max-w-[500px]">
          <!-- Blue glow behind -->
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="w-64 h-64 rounded-full bg-blue/20 blur-[80px]"></div>
          </div>

          <!-- Page 5 (far back-left) -->
          <div class="absolute top-[15%] left-[2%] w-[140px] h-[180px] md:w-[160px] md:h-[200px] rounded-lg shadow-md" style="background:#1E293B; border:1px solid #334155; transform:rotate(-12deg) translateY(10px);">
            <div class="p-3 space-y-1.5">
              <div class="w-3/4 h-1.5 rounded-full" style="background:#334155;"></div>
              <div class="w-1/2 h-1.5 rounded-full" style="background:#334155;"></div>
              <div class="w-5/6 h-1.5 rounded-full" style="background:#334155;"></div>
              <div class="w-2/3 h-1.5 rounded-full" style="background:#334155;"></div>
            </div>
          </div>

          <!-- Page 4 (back-right) -->
          <div class="absolute top-[12%] right-[2%] w-[140px] h-[180px] md:w-[160px] md:h-[200px] rounded-lg shadow-md" style="background:#1E293B; border:1px solid #334155; transform:rotate(10deg) translateY(8px);">
            <div class="p-3 space-y-1.5">
              <div class="w-2/3 h-1.5 rounded-full" style="background:#334155;"></div>
              <div class="w-4/5 h-1.5 rounded-full" style="background:#334155;"></div>
              <div class="w-1/2 h-1.5 rounded-full" style="background:#334155;"></div>
            </div>
          </div>

          <!-- Page 3 (mid-left) -->
          <div class="absolute top-[20%] left-[10%] w-[150px] h-[190px] md:w-[170px] md:h-[215px] rounded-lg shadow-lg" style="background:#253247; border:1px solid #3B4F6B; transform:rotate(-7deg);">
            <div class="p-3 space-y-1.5">
              <div class="w-10 h-1.5 rounded-full bg-blue/40"></div>
              <div class="w-3/4 h-2 rounded-full" style="background:#3B4F6B;"></div>
              <div class="w-full h-1 rounded-full" style="background:#334155;"></div>
              <div class="w-5/6 h-1 rounded-full" style="background:#334155;"></div>
              <div class="w-2/3 h-1 rounded-full" style="background:#334155;"></div>
            </div>
          </div>

          <!-- Page 2 (mid-right) -->
          <div class="absolute top-[18%] right-[8%] w-[150px] h-[190px] md:w-[170px] md:h-[215px] rounded-lg shadow-lg" style="background:#253247; border:1px solid #3B4F6B; transform:rotate(5deg);">
            <div class="p-3 space-y-1.5">
              <div class="w-10 h-1.5 rounded-full bg-blue/40"></div>
              <div class="w-2/3 h-2 rounded-full" style="background:#3B4F6B;"></div>
              <div class="w-full h-1 rounded-full" style="background:#334155;"></div>
              <div class="w-4/5 h-1 rounded-full" style="background:#334155;"></div>
              <div class="w-3/4 h-1 rounded-full" style="background:#334155;"></div>
            </div>
          </div>

          <!-- Main Cover Document (centered, on top) -->
          <div class="absolute top-[10%] left-1/2 -translate-x-1/2 w-[180px] h-[230px] md:w-[210px] md:h-[270px] rounded-xl shadow-2xl z-10" style="background:#F8FAFC; border:2px solid rgba(0,59,224,0.5);">
            <div class="p-5 space-y-3">
              <div class="w-16 h-2 rounded-full bg-blue"></div>
              <div class="font-chivo font-bold text-[9px] md:text-[10px] leading-tight" style="color:#0B0F19;">
                SDR Outbound<br/>Scaling Framework
              </div>
              <div class="w-full h-[1px]" style="background:#CBD5E1;"></div>
              <div class="space-y-1.5">
                <div class="w-full h-1 rounded-full" style="background:#E2E8F0;"></div>
                <div class="w-5/6 h-1 rounded-full" style="background:#E2E8F0;"></div>
                <div class="w-full h-1 rounded-full" style="background:#E2E8F0;"></div>
                <div class="w-4/5 h-1 rounded-full" style="background:#E2E8F0;"></div>
                <div class="w-2/3 h-1 rounded-full" style="background:#E2E8F0;"></div>
                <div class="w-full h-1 rounded-full" style="background:#E2E8F0;"></div>
                <div class="w-3/4 h-1 rounded-full" style="background:#E2E8F0;"></div>
              </div>
              <div class="mt-2 w-20 h-5 rounded bg-blue/10 flex items-center justify-center">
                <span class="font-chivo font-bold text-[7px] text-blue">SalesAtScale.io</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Opt-in Form -->
      <div class="w-full lg:w-1/2">
        <div class="rounded-2xl p-8 backdrop-blur" style="background:rgba(30,41,59,0.8); border:1px solid #334155;">
          <h3 class="font-chivo font-bold text-2xl md:text-[28px] leading-tight mb-8" style="color:#F8FAFC;">
            Enter Your Info Below To Get Access For Free
          </h3>

          <form class="flex flex-col gap-5" action="#" method="POST">
            <!-- First Name -->
            <div class="flex flex-col gap-2">
              <label for="first-name" class="font-chivo font-medium text-sm" style="color:#94A3B8;">First Name</label>
              <input
                type="text"
                id="first-name"
                name="first_name"
                required
                placeholder="Enter your first name..."
                class="w-full px-4 py-3 rounded-lg font-chivo text-sm bg-base focus:border-blue focus:ring-1 focus:ring-blue outline-none transition-all"
                style="border:1px solid #334155; color:#F8FAFC;"
              />
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-2">
              <label for="email" class="font-chivo font-medium text-sm" style="color:#94A3B8;">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="Enter your email address..."
                class="w-full px-4 py-3 rounded-lg font-chivo text-sm bg-base focus:border-blue focus:ring-1 focus:ring-blue outline-none transition-all"
                style="border:1px solid #334155; color:#F8FAFC;"
              />
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full mt-2 px-8 py-4 bg-blue hover:bg-blue-hover text-white font-chivo font-bold text-sm rounded-md shadow-btn-glow hover:shadow-btn-glow-hover transition-all hover:-translate-y-0.5 uppercase tracking-widest flex items-center justify-center gap-3"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              Get Instant Access
            </button>

            <p class="text-center font-chivo text-xs mt-1" style="color:#64748B;">
              Instantly sent to your email. No spam, ever.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- What Will You Learn -->
  <section class="w-full py-24 bg-surface" style="border-top:1px solid #334155; border-bottom:1px solid #334155;">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-chivo font-black text-3xl md:text-4xl lg:text-[44px] leading-[1.1] tracking-tight text-center mb-16" style="color:#F8FAFC;">
        What Will You Learn?
      </h2>

      <div class="flex flex-col gap-10">
        <!-- Bullet 1 -->
        <div class="flex items-start gap-5">
          <div class="mt-2 w-3 h-3 rounded-full bg-blue shrink-0 shadow-[0_0_12px_rgba(0,59,224,0.6)]"></div>
          <div>
            <h3 class="font-chivo font-bold text-lg md:text-xl mb-2" style="color:#F8FAFC;">
              The "10 Commandments" Of Outbound...
            </h3>
            <p class="font-chivo font-medium text-[16px] leading-relaxed" style="color:#94A3B8;">
              The exact rules we follow to build outbound campaigns that consistently sign $10k/mo+ clients without burning through lead lists or annoying prospects.
            </p>
          </div>
        </div>

        <!-- Bullet 2 -->
        <div class="flex items-start gap-5">
          <div class="mt-2 w-3 h-3 rounded-full bg-blue shrink-0 shadow-[0_0_12px_rgba(0,59,224,0.6)]"></div>
          <div>
            <h3 class="font-chivo font-bold text-lg md:text-xl mb-2" style="color:#F8FAFC;">
              The Exact 10 Step Process
            </h3>
            <p class="font-chivo font-medium text-[16px] leading-relaxed" style="color:#94A3B8;">
              How to install a fully automated SDR infrastructure from scratch -- including tech stack, sequences, daily workflows, and KPI dashboards your team follows every single day.
            </p>
          </div>
        </div>

        <!-- Bullet 3 -->
        <div class="flex items-start gap-5">
          <div class="mt-2 w-3 h-3 rounded-full bg-blue shrink-0 shadow-[0_0_12px_rgba(0,59,224,0.6)]"></div>
          <div>
            <h3 class="font-chivo font-bold text-lg md:text-xl mb-2" style="color:#F8FAFC;">
              Exactly How We Signed Elite Masterminds
            </h3>
            <p class="font-chivo font-medium text-[16px] leading-relaxed" style="color:#94A3B8;">
              A behind-the-scenes breakdown of the lead-scraping, personalization frameworks, and multi-touch sequences we used to land one of our biggest accounts.
            </p>
          </div>
        </div>

        <!-- Bullet 4 -->
        <div class="flex items-start gap-5">
          <div class="mt-2 w-3 h-3 rounded-full bg-blue shrink-0 shadow-[0_0_12px_rgba(0,59,224,0.6)]"></div>
          <div>
            <h3 class="font-chivo font-bold text-lg md:text-xl mb-2" style="color:#F8FAFC;">
              What Actually Is A "Sales Infrastructure"?
            </h3>
            <p class="font-chivo font-medium text-[16px] leading-relaxed" style="color:#94A3B8;">
              We break down exactly what a scalable sales infrastructure looks like, piece by piece, so you can build yours to handle 100+ calls per month without bottlenecks.
            </p>
          </div>
        </div>
      </div>

      <!-- And much more -->
      <div class="text-center mt-10 mb-12">
        <span class="font-chivo font-bold text-blue text-lg">And much more...</span>
      </div>

      <!-- Full-width CTA -->
      <a href="#" onclick="document.getElementById('first-name').focus(); window.scrollTo({top:0,behavior:'smooth'}); return false;" class="block w-full px-8 py-5 bg-blue hover:bg-blue-hover text-white font-chivo font-bold text-sm rounded-md shadow-btn-glow hover:shadow-btn-glow-hover transition-all hover:-translate-y-0.5 uppercase tracking-widest text-center no-underline">
        Get Instant Access
      </a>
    </div>
  </section>
</BaseLayout>
