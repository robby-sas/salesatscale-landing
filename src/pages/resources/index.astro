---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Scripts & SOPs — Free Sales Resources | SalesAtScale.io"
  description="Download the exact frameworks, hiring pipelines, and closing scripts we deploy for our private clients. 100% free."
>
  <!-- Header -->
  <header class="w-full max-w-5xl mx-auto px-6 pt-32 pb-16 text-center">
    <div class="inline-block mb-6 px-4 py-1.5 rounded-full font-chivo font-bold text-sm tracking-wide text-blue" style="border:1px solid rgba(0,59,224,0.4); background:rgba(0,59,224,0.08);">
      Free Resources
    </div>
    <h1 class="font-chivo font-black text-4xl md:text-5xl lg:text-[56px] leading-[1.1] tracking-tight mb-6" style="color:#F8FAFC;">
      The Internal Documents We Use To <br class="hidden md:block" />
      <span class="text-blue">Scale 7-Figure Sales Teams</span>
    </h1>
    <p class="font-chivo font-medium text-[18px] md:text-[20px] leading-relaxed max-w-4xl mx-auto" style="color:#94A3B8;">
      Swipe the exact frameworks, hiring pipelines, and closing scripts we deploy for our private clients. No opt-in walls. No fluff. Just the documents that actually move the needle.
    </p>
  </header>

  <!-- Resource Cards -->
  <main class="w-full max-w-6xl mx-auto px-6 flex flex-col gap-12 pb-24">

    <!-- Resource Card #1: SDR Outbound Scaling Framework -->
    <a href="/resources/outbound-scaling/" class="group block w-full rounded-3xl p-8 md:p-12 transition-all duration-500 hover:-translate-y-1 relative overflow-hidden no-underline bg-surface" style="border:1px solid #334155;" onmouseenter="this.style.borderColor='rgba(0,59,224,0.6)';this.style.boxShadow='0 20px 60px rgba(0,59,224,0.15)'" onmouseleave="this.style.borderColor='#334155';this.style.boxShadow='none'">
      <div class="absolute inset-0 bg-gradient-to-br from-blue/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
      <div class="flex flex-col lg:flex-row gap-12 items-center relative z-10">
        <!-- Left: Text -->
        <div class="w-full lg:w-[55%] flex flex-col justify-center">
          <div class="w-fit mb-6 px-4 py-1.5 rounded-full font-chivo font-bold text-sm tracking-wide" style="border:1px solid #334155; color:#F8FAFC;">
            SOP Collection #1
          </div>
          <h2 class="font-chivo font-black text-3xl md:text-4xl leading-tight tracking-tight mb-6" style="color:#F8FAFC;">
            SDR Outbound Scaling Framework
          </h2>
          <div class="font-chivo font-medium text-[17px] leading-relaxed mb-8 space-y-4" style="color:#94A3B8;">
            <p>The complete outbound scaling documentation we use internally to take clients from 0 to 100+ qualified calls per month. Includes cadence structures, follow-up strategies, daily KPI tracking sheets, and the exact scripts our SDRs run on day one.</p>
          </div>
          <div class="inline-flex items-center gap-3 px-8 py-4 bg-blue hover:bg-blue-hover text-white font-chivo font-bold text-sm rounded-md shadow-btn-glow hover:shadow-btn-glow-hover transition-all uppercase tracking-widest w-fit">
            Get Access Now
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-white/20 group-hover:bg-white/30 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
        <!-- Right: Stacked Documents -->
        <div class="w-full lg:w-[45%] flex items-center justify-center">
          <div class="relative w-[280px] h-[340px] md:w-[320px] md:h-[380px]">
            <!-- Back page -->
            <div class="absolute top-4 left-6 w-[200px] h-[260px] md:w-[230px] md:h-[290px] rounded-xl shadow-lg transition-transform duration-500 group-hover:rotate-[-8deg] group-hover:-translate-x-2" style="background:#1E293B; border:1px solid #334155; transform:rotate(-6deg);">
              <div class="p-4 space-y-2">
                <div class="w-3/4 h-2 rounded-full" style="background:#334155;"></div>
                <div class="w-1/2 h-2 rounded-full" style="background:#334155;"></div>
                <div class="w-5/6 h-2 rounded-full" style="background:#334155;"></div>
              </div>
            </div>
            <!-- Middle page -->
            <div class="absolute top-2 left-3 w-[200px] h-[260px] md:w-[230px] md:h-[290px] rounded-xl shadow-lg transition-transform duration-500 group-hover:rotate-[-3deg] group-hover:-translate-x-1" style="background:#253247; border:1px solid #334155; transform:rotate(-3deg);">
              <div class="p-4 space-y-2">
                <div class="w-2/3 h-2 rounded-full" style="background:#3B4F6B;"></div>
                <div class="w-4/5 h-2 rounded-full" style="background:#3B4F6B;"></div>
                <div class="w-1/2 h-2 rounded-full" style="background:#3B4F6B;"></div>
              </div>
            </div>
            <!-- Front page -->
            <div class="absolute top-0 left-0 w-[200px] h-[260px] md:w-[230px] md:h-[290px] rounded-xl shadow-lg transition-transform duration-500 group-hover:rotate-[2deg] group-hover:translate-x-1" style="background:#F8FAFC; border:2px solid rgba(0,59,224,0.4);">
              <div class="p-5 space-y-3">
                <div class="w-16 h-2 rounded-full bg-blue"></div>
                <div class="w-3/4 h-3 rounded-full" style="background:#1E293B;"></div>
                <div class="w-full h-1.5 rounded-full" style="background:#CBD5E1;"></div>
                <div class="w-5/6 h-1.5 rounded-full" style="background:#CBD5E1;"></div>
                <div class="w-2/3 h-1.5 rounded-full" style="background:#CBD5E1;"></div>
                <div class="mt-4 w-full h-1 rounded-full" style="background:#E2E8F0;"></div>
                <div class="w-4/5 h-1 rounded-full" style="background:#E2E8F0;"></div>
                <div class="w-full h-1 rounded-full" style="background:#E2E8F0;"></div>
                <div class="w-3/5 h-1 rounded-full" style="background:#E2E8F0;"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </a>

    <!-- Resource Card #2: The High-Ticket Closer Script -->
    <a href="/resources/closer-script/" class="group block w-full rounded-3xl p-8 md:p-12 transition-all duration-500 hover:-translate-y-1 relative overflow-hidden no-underline bg-surface" style="border:1px solid #334155;" onmouseenter="this.style.borderColor='rgba(0,59,224,0.6)';this.style.boxShadow='0 20px 60px rgba(0,59,224,0.15)'" onmouseleave="this.style.borderColor='#334155';this.style.boxShadow='none'">
      <div class="absolute inset-0 bg-gradient-to-br from-blue/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
      <div class="flex flex-col lg:flex-row gap-12 items-center relative z-10">
        <!-- Left: Text -->
        <div class="w-full lg:w-[55%] flex flex-col justify-center">
          <div class="w-fit mb-6 px-4 py-1.5 rounded-full font-chivo font-bold text-sm tracking-wide" style="border:1px solid #334155; color:#F8FAFC;">
            Script #1
          </div>
          <h2 class="font-chivo font-black text-3xl md:text-4xl leading-tight tracking-tight mb-6" style="color:#F8FAFC;">
            The High-Ticket Closer Script
          </h2>
          <div class="font-chivo font-medium text-[17px] leading-relaxed mb-8 space-y-4" style="color:#94A3B8;">
            <p>The word-for-word discovery and closing script our team uses to close $10k+ deals on cold traffic. Includes the complete objection handling matrix, tonality guides, and the 4-phase framework that separates top 1% closers from everyone else.</p>
          </div>
          <div class="inline-flex items-center gap-3 px-8 py-4 bg-blue hover:bg-blue-hover text-white font-chivo font-bold text-sm rounded-md shadow-btn-glow hover:shadow-btn-glow-hover transition-all uppercase tracking-widest w-fit">
            Get Access Now
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-white/20 group-hover:bg-white/30 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </div>
        <!-- Right: Stacked Documents -->
        <div class="w-full lg:w-[45%] flex items-center justify-center">
          <div class="relative w-[280px] h-[340px] md:w-[320px] md:h-[380px]">
            <!-- Back page -->
            <div class="absolute top-4 right-6 w-[200px] h-[260px] md:w-[230px] md:h-[290px] rounded-xl shadow-lg transition-transform duration-500 group-hover:rotate-[8deg] group-hover:translate-x-2" style="background:#1E293B; border:1px solid #334155; transform:rotate(6deg);">
              <div class="p-4 space-y-2">
                <div class="w-3/4 h-2 rounded-full" style="background:#334155;"></div>
                <div class="w-1/2 h-2 rounded-full" style="background:#334155;"></div>
                <div class="w-5/6 h-2 rounded-full" style="background:#334155;"></div>
              </div>
            </div>
            <!-- Middle page -->
            <div class="absolute top-2 right-3 w-[200px] h-[260px] md:w-[230px] md:h-[290px] rounded-xl shadow-lg transition-transform duration-500 group-hover:rotate-[3deg] group-hover:translate-x-1" style="background:#253247; border:1px solid #334155; transform:rotate(3deg);">
              <div class="p-4 space-y-2">
                <div class="w-2/3 h-2 rounded-full" style="background:#3B4F6B;"></div>
                <div class="w-4/5 h-2 rounded-full" style="background:#3B4F6B;"></div>
                <div class="w-1/2 h-2 rounded-full" style="background:#3B4F6B;"></div>
              </div>
            </div>
            <!-- Front page -->
            <div class="absolute top-0 right-0 w-[200px] h-[260px] md:w-[230px] md:h-[290px] rounded-xl shadow-lg transition-transform duration-500 group-hover:rotate-[-2deg] group-hover:-translate-x-1" style="background:#F8FAFC; border:2px solid rgba(0,59,224,0.4);">
              <div class="p-5 space-y-3">
                <div class="w-16 h-2 rounded-full bg-blue"></div>
                <div class="w-3/4 h-3 rounded-full" style="background:#1E293B;"></div>
                <div class="w-full h-1.5 rounded-full" style="background:#CBD5E1;"></div>
                <div class="w-5/6 h-1.5 rounded-full" style="background:#CBD5E1;"></div>
                <div class="w-2/3 h-1.5 rounded-full" style="background:#CBD5E1;"></div>
                <div class="mt-4 w-full h-1 rounded-full" style="background:#E2E8F0;"></div>
                <div class="w-4/5 h-1 rounded-full" style="background:#E2E8F0;"></div>
                <div class="w-full h-1 rounded-full" style="background:#E2E8F0;"></div>
                <div class="w-3/5 h-1 rounded-full" style="background:#E2E8F0;"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </a>

  </main>
</BaseLayout>
