---
import BaseLayout from "./BaseLayout.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import ShareButtons from "../components/ui/ShareButtons.astro";
import { siteConfig } from "../../site.config";
import { buildUrl, formatDate, formatDateISO } from "../utils/seo";
import { formatReadingTime } from "../utils/reading-time";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  heroImageAlt?: string;
  author?: string;
  category?: string;
  tags?: string[];
  readingTime?: number;
  slug: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroImageAlt = "",
  author = siteConfig.blog.defaultAuthor.name,
  category,
  tags = [],
  readingTime,
  slug,
} = Astro.props;

const articleUrl = buildUrl(`/blog/${slug}/`);
const publishedISO = formatDateISO(pubDate);
const modifiedISO = updatedDate ? formatDateISO(updatedDate) : undefined;
const breadcrumbItems = [
  { name: "Blog", url: buildUrl("/blog/") },
  { name: title, url: articleUrl },
];
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  type="article"
  publishedTime={publishedISO}
  modifiedTime={modifiedISO}
  author={author}
  section={category}
  tags={tags}
>
  <JsonLd
    article={{
      headline: title,
      description,
      image: heroImage,
      datePublished: publishedISO,
      dateModified: modifiedISO,
      author,
      section: category,
      tags,
      url: articleUrl,
    }}
  />

  <article class="blog-post section">
    <div class="container">
      <Breadcrumbs items={breadcrumbItems} />

      <header class="post-header">
        <div class="post-meta">
          {category && (
            <a href={buildUrl(`/blog/category/${category.toLowerCase()}/`)} class="post-category">
              {category}
            </a>
          )}
          <time datetime={publishedISO}>{formatDate(pubDate)}</time>
          {readingTime && <span>{formatReadingTime(readingTime)}</span>}
        </div>

        <h1>{title}</h1>

        <div class="post-author">
          <span>By {author}</span>
        </div>

        <ShareButtons url={articleUrl} title={title} description={description} />
      </header>

      {heroImage && (
        <img
          src={heroImage}
          alt={heroImageAlt}
          class="post-hero"
          loading="eager"
          decoding="async"
          width="1200"
          height="630"
        />
      )}

      <div class="post-content article-summary">
        <slot />
      </div>

      {tags.length > 0 && (
        <div class="post-tags">
          <span class="tags-label">Tags:</span>
          {tags.map((tag) => (
            <a href={buildUrl(`/blog/tag/${tag.toLowerCase()}/`)} class="tag">
              {tag}
            </a>
          ))}
        </div>
      )}

      <div class="post-footer">
        <ShareButtons url={articleUrl} title={title} description={description} />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    max-width: var(--max-width-content);
    margin-bottom: var(--space-8);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .post-category {
    background: var(--color-surface);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .post-category:hover {
    background: var(--color-primary);
    color: #ffffff;
  }

  h1 {
    margin-bottom: var(--space-4);
  }

  .post-author {
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .post-hero {
    width: 100%;
    max-width: var(--max-width-content);
    height: auto;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-8);
  }

  .post-content {
    max-width: var(--max-width-content);
  }

  .post-content :global(h2) {
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }

  .post-content :global(h3) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .post-content :global(p) {
    margin-bottom: var(--space-4);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }

  .post-content :global(li) {
    margin-bottom: var(--space-2);
  }

  .post-content :global(img) {
    border-radius: var(--radius-md);
    max-width: 100%;
    height: auto;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    max-width: var(--max-width-content);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .tags-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .tag {
    font-size: var(--text-sm);
    padding: var(--space-1) var(--space-3);
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .tag:hover {
    background: var(--color-primary);
    color: #ffffff;
  }

  .post-footer {
    max-width: var(--max-width-content);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }
</style>
