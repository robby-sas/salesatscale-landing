---
const phases = [
  {
    title: "MIND (Alignment)",
    items: [
      "Audit your unit economics, offer structure, and sales messaging.",
      "Map out the psychological roadmap of your buyers.",
      "Ensure your offer and pricing are optimized to absorb high-volume deal flow profitably.",
    ],
  },
  {
    title: "Systems Buildout",
    items: [
      "Install proprietary CRM tracking infrastructure.",
      "Build automated follow-up sequences and pipeline stages.",
      "Create airtight SOPs for every stage of the sales process.",
      "Achieve 100% visibility into your revenue pipeline.",
    ],
  },
  {
    title: "Installing Setters & Closers",
    items: [
      "Source, aggressively vet, and place top 1% sales talent.",
      "Train reps specifically to your model, offer, and brand language.",
      "Hand over a fully trained, performance-driven team ready on day one.",
      "Zero resumes, zero interviews — we handle everything.",
    ],
  },
  {
    title: "Revenue Orchestration",
    items: [
      "Act as your Fractional VP of Sales.",
      "Run daily huddles, conduct call reviews, and optimize scripts.",
      "Continuously push close rates higher with data-driven coaching.",
      "Manage the floor, track the KPIs, and scale the revenue.",
    ],
  },
];
---

<section class="bg-base py-24 relative overflow-hidden" id="how-we-work">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-glow rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-[280px_1fr] gap-16">
      <!-- Left: Sticky title -->
      <div class="lg:sticky lg:top-32 lg:self-start">
        <h2 class="font-chivo font-black text-heading text-4xl md:text-5xl tracking-[-0.03em] leading-[1] mb-4">How We Work</h2>
        <p class="font-jakarta font-light text-body text-base leading-relaxed">Our System to Automate Your Sales</p>
      </div>

      <!-- Right: Timeline -->
      <div class="relative" id="timeline-container">
        <!-- Vertical line background (dimmed track) -->
        <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-card-border/30 rounded-full"></div>
        <!-- Vertical line progress (fills as you scroll) -->
        <div id="timeline-bar" class="absolute left-6 top-0 w-0.5 rounded-full bg-blue origin-top" style="height: 0; transition: height 0.15s linear; box-shadow: 0 0 8px rgba(0,59,224,0.5);"></div>

        {phases.map((phase, i) => (
          <div class="timeline-phase relative pl-16 pb-24 last:pb-0" data-phase={i}>
            <!-- Node circle -->
            <div class="timeline-node absolute left-0 w-12 h-12 rounded-full flex items-center justify-center border-2 bg-card border-card-border text-body/30" style="transition: all 0.5s cubic-bezier(.4,0,.2,1);">
              {i === 0 && (
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              )}
              {i === 1 && (
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              )}
              {i === 2 && (
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              )}
              {i === 3 && (
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
              )}
            </div>

            <!-- Phase content -->
            <div class="timeline-content" style="opacity: 0.15; transform: translateY(12px); transition: opacity 0.6s ease-out, transform 0.6s ease-out;">
              <h3 class="font-chivo font-black text-heading text-2xl tracking-[-0.02em] mb-6">{phase.title}</h3>
              <ul class="space-y-4">
                {phase.items.map((item, j) => (
                  <li class="timeline-item flex items-start gap-3" style={`opacity: 0; transform: translateY(8px); transition: opacity 0.4s ease-out ${j * 0.1}s, transform 0.4s ease-out ${j * 0.1}s;`}>
                    <svg class="w-5 h-5 text-blue flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    <span class="font-jakarta font-medium text-body text-sm leading-relaxed">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function runTimeline() {
    const container = document.getElementById('timeline-container');
    const bar = document.getElementById('timeline-bar');
    const phases = document.querySelectorAll('.timeline-phase');
    if (!container || !bar || !phases.length) return;

    let ticking = false;

    function update() {
      const containerRect = container.getBoundingClientRect();
      const containerTop = containerRect.top;
      const containerHeight = containerRect.height;
      const trigger = window.innerHeight * 0.6; // 60% down the viewport

      // How far the trigger line is into the container (0 to 1)
      const scrolled = (trigger - containerTop) / containerHeight;
      const progress = Math.max(0, Math.min(scrolled, 1));

      // Animate the blue progress bar height
      bar.style.height = `${progress * 100}%`;

      // For each phase, check if the progress bar has reached it
      phases.forEach((phase) => {
        const el = phase as HTMLElement;
        const node = el.querySelector('.timeline-node') as HTMLElement;
        const content = el.querySelector('.timeline-content') as HTMLElement;
        const items = el.querySelectorAll('.timeline-item') as NodeListOf<HTMLElement>;

        // Position of this phase's node relative to the container
        const nodeTop = el.offsetTop + 24; // center of 48px node
        const nodeProgress = nodeTop / containerHeight;

        if (progress >= nodeProgress) {
          // Phase is reached — light it up
          node.style.backgroundColor = '#003be0';
          node.style.borderColor = '#003be0';
          node.style.color = 'white';
          node.style.boxShadow = '0 0 20px rgba(0,59,224,0.5), 0 0 40px rgba(0,59,224,0.2)';

          content.style.opacity = '1';
          content.style.transform = 'translateY(0)';

          items.forEach((item) => {
            item.style.opacity = '1';
            item.style.transform = 'translateY(0)';
          });
        } else {
          // Phase not yet reached — keep dim
          node.style.backgroundColor = '#1E293B';
          node.style.borderColor = '#334155';
          node.style.color = 'rgba(255,255,255,0.2)';
          node.style.boxShadow = 'none';

          content.style.opacity = '0.15';
          content.style.transform = 'translateY(12px)';

          items.forEach((item) => {
            item.style.opacity = '0';
            item.style.transform = 'translateY(8px)';
          });
        }
      });

      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    update(); // run once on load
  }

  // Init
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runTimeline);
  } else {
    runTimeline();
  }
  document.addEventListener('astro:page-load', runTimeline);
</script>
