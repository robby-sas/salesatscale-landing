---
const steps = [
  {
    number: "01",
    timeframe: "Days 1-3",
    title: "MIND (Alignment)",
    items: [
      "Audit your unit economics, offer structure, and sales messaging.",
      "Map out the psychological roadmap of your buyers.",
      "Ensure your offer and pricing are optimized to absorb high-volume deal flow profitably.",
    ],
    mt: "md:mt-[80px]",
    dy: -80,
  },
  {
    number: "02",
    timeframe: "Days 4-7",
    title: "Systems Buildout",
    items: [
      "Install proprietary CRM tracking infrastructure.",
      "Build automated follow-up sequences and pipeline stages.",
      "Create airtight SOPs for every stage of the sales process.",
      "Achieve 100% visibility into your revenue pipeline.",
    ],
    mt: "md:mt-[0px]",
    dy: 120,
  },
  {
    number: "03",
    timeframe: "Week 2",
    title: "Installing Setters",
    items: [
      "Source, vet, and place top 1% sales talent specifically for your offer.",
      "Intensive training on your unique psychological roadmap.",
      "Deploy and manage the team on a purely performance basis.",
    ],
    mt: "md:mt-[120px]",
    dy: -80,
  },
  {
    number: "04",
    timeframe: "Day 14 & Beyond",
    title: "Active Management",
    items: [
      "Daily KPI tracking and continuous performance reviews.",
      "Live call QA and weekly optimization training.",
      "Scale lead volume confidently as conversion benchmarks are hit.",
    ],
    mt: "md:mt-[40px]",
    dy: 0,
  },
];
---

<section class="bg-[#050505] overflow-hidden" id="how-we-work">
  <div class="max-w-7xl mx-auto px-6 py-24 md:py-32">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between pb-8 md:pb-16">
      <div class="max-w-2xl">
        <span class="text-blue font-chivo font-bold tracking-widest uppercase text-xs mb-4 block">Infrastructure</span>
        <h2 class="font-chivo font-bold text-5xl md:text-7xl tracking-tight leading-[1.1]" style="color:#FFFFFF;">How We Work</h2>
      </div>
      <p class="font-chivo font-light text-lg md:text-xl max-w-md mt-8 md:mt-0 md:text-right" style="color:#9CA3AF;">
        Our rigid, uncompromising system to audit, build, and deploy a scalable 7-figure sales engine <strong class="font-semibold" style="color:#FFFFFF;">in just 14 days.</strong>
      </p>
    </div>

    <!-- Floating Process Map -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-y-12 md:gap-y-0 relative z-10 pt-12 pb-32">
      {steps.map((step, index) => (
        <div class={`relative flex flex-col w-full group ${step.mt}`}>

          {/* Mobile vertical connecting line */}
          {index < steps.length - 1 && (
            <div class="absolute left-[1.125rem] top-8 bottom-[-4rem] w-px md:hidden z-0 pointer-events-none" style="background:#1f2937;"></div>
          )}

          {/* Timeframe above the node */}
          <div class="pl-12 md:pl-0 mb-6 md:text-center md:flex md:justify-center">
            <span class="font-mono text-xs uppercase tracking-widest text-blue relative z-10 px-2 group-hover:text-blue-light transition-colors duration-300" style="background:#050505;">
              {step.timeframe}
            </span>
          </div>

          {/* Node & connecting line layer */}
          <div class="relative w-full h-0 z-0">
            {/* Desktop SVG connecting line */}
            {index < steps.length - 1 && (
              <svg class="hidden md:block absolute top-0 left-1/2 w-full overflow-visible pointer-events-none" style="height:1px; z-index:0;">
                <line x1="0" y1="0" x2="100%" y2={step.dy} stroke="#1f2937" stroke-width="2" />
              </svg>
            )}

            {/* Diamond node */}
            <div class="absolute top-0 left-[1.125rem] md:left-1/2 -translate-x-1/2 -translate-y-1/2 w-3 h-3 rotate-45 z-10 group-hover:shadow-[0_0_15px_rgba(0,59,224,0.6)] transition-all duration-300" style="background:#050505; border:2px solid #1f2937;" onmouseenter="this.style.borderColor='#003BE0';this.style.background='#003BE0'" onmouseleave="this.style.borderColor='#1f2937';this.style.background='#050505'"></div>
          </div>

          {/* Content card */}
          <div class="ml-12 md:mx-4 lg:mx-6 mt-6 p-6 md:p-8 relative overflow-hidden group-hover:border-gray-600 transition-colors duration-300 flex-grow" style="border:1px solid rgba(31,41,55,0.6); background:#0A0A0A;">

            {/* Giant background number */}
            <div class="absolute -bottom-6 -right-4 text-8xl md:text-9xl font-chivo font-black pointer-events-none select-none" style="color:#151515;">{step.number}</div>

            {/* Card content */}
            <div class="relative z-10">
              <h3 class="font-chivo font-bold text-xl lg:text-2xl mb-6 tracking-tight" style="color:#FFFFFF;">{step.title}</h3>
              <ul class="space-y-4">
                {step.items.map((item) => (
                  <li class="flex items-start">
                    <div class="w-1.5 h-1.5 bg-blue mt-2.5 mr-3 flex-shrink-0"></div>
                    <span class="font-chivo font-light text-sm md:text-base leading-relaxed" style="color:#9CA3AF;">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
