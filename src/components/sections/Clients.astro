---
const clients = [
  { name: "Dean Graziosi", image: "https://placehold.co/600x375/111827/475569?text=Image+Slot" },
  { name: "Frank Kern", image: "https://placehold.co/600x375/111827/475569?text=Image+Slot" },
  { name: "Russ Ruffino", image: "https://placehold.co/600x375/111827/475569?text=Image+Slot" },
  { name: "Todd Brown", image: "https://placehold.co/600x375/111827/475569?text=Image+Slot" },
  { name: "Jay Abraham", image: "https://placehold.co/600x375/111827/475569?text=Image+Slot" },
  { name: "Aleric Heck", image: "https://placehold.co/600x375/111827/475569?text=Image+Slot" },
  { name: "Rich Schefren", image: "https://placehold.co/600x375/111827/475569?text=Image+Slot" },
  { name: "Tanner Chidester", image: "https://placehold.co/600x375/111827/475569?text=Image+Slot" },
];
---

<section class="bg-[#050505] pt-12 pb-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="scroll-animate mb-16">
      <span class="font-jakarta font-semibold text-xs tracking-[0.18em] uppercase text-[#003BE0] mb-4 block">Our Clients</span>
      <h2 class="font-chivo font-black text-[#F8FAFC] text-4xl md:text-5xl tracking-[-0.03em] leading-[1]">
        Meet Our Clients Who Use<br/>SalesAtScale.io
      </h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5 w-full">
      {clients.map((client) => (
        <div class="scroll-animate group relative bg-[#0A0A0A] rounded-none overflow-hidden flex flex-col border border-[#1F2937] hover:border-[#003BE0] transition-colors duration-300">
          <!-- Image -->
          <div class="w-full bg-[#070A11] relative overflow-hidden" style="aspect-ratio: 16/10;">
            <img
              src={client.image}
              alt={`${client.name} — SalesAtScale.io client`}
              class="w-full h-full object-cover"
              width="600"
              height="375"
              loading="lazy"
              decoding="async"
            />
          </div>

          <!-- Name Strip -->
          <div class="py-4 bg-[#0A0A0A] flex justify-center items-center">
            <span class="font-jakarta font-medium text-[#F8FAFC] text-[15px] tracking-wide">{client.name}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <a href="/apply/" class="group inline-flex items-center gap-2 bg-[#003BE0] hover:bg-[#0044FF] text-white font-chivo font-bold text-sm md:text-base tracking-[0.08em] uppercase px-12 md:px-16 py-4 md:py-5 rounded-full transition-colors duration-300">
        APPLY NOW
        <svg class="w-4 h-4 md:w-5 md:h-5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
  </div>
</section>
