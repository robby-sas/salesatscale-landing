---
import { siteConfig } from "../../../site.config";
const { cta } = siteConfig;
---

<section class="relative h-screen bg-[#050505] pt-20 pb-6 overflow-hidden">
  <div class="relative z-10 max-w-6xl mx-auto px-6 h-full">
    <div class="flex flex-col items-center justify-start pt-14 md:pt-16 h-full gap-4 md:gap-5">
      <!-- Headline -->
      <div class="scroll-animate text-center w-full max-w-4xl">
        <h1 class="font-chivo font-black text-[#F8FAFC] leading-[0.92] tracking-[-0.035em] text-5xl md:text-6xl lg:text-7xl mb-2">
          We Close. <span class="text-[#003BE0]">You Scale.</span>
        </h1>
        <p class="font-jakarta font-normal text-[#9CA3AF] text-sm md:text-base tracking-normal max-w-xl mx-auto leading-relaxed">
          We recruit, train, and manage your sales team on a performance-only basis.
        </p>
      </div>

      <!-- Video / VSL -->
      <div class="scroll-animate w-full max-w-3xl flex-shrink-0">
        <div class="relative rounded-none overflow-hidden bg-[#0A0A0A] border border-[#1F2937] aspect-video">
          <img
            src="https://placehold.co/960x540/1E293B/003be0?text=VSL+Video"
            alt="SalesAtScale.io overview video"
            class="w-full h-full object-cover"
            width="960"
            height="540"
            loading="eager"
          />
          <div class="absolute inset-0 flex items-center justify-center">
            <button class="w-16 h-16 md:w-20 md:h-20 bg-[#003BE0] rounded-full flex items-center justify-center hover:bg-[#0044FF] transition-colors duration-300" aria-label="Play video">
              <svg class="w-6 h-6 md:w-8 md:h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="scroll-animate text-center w-full">
        <a href={cta.primary.url} class="group inline-flex items-center gap-2 bg-[#003BE0] hover:bg-[#0044FF] text-white font-chivo font-bold text-sm md:text-base tracking-[0.08em] uppercase px-12 md:px-16 py-4 md:py-5 rounded-full transition-colors duration-300">
          {cta.primary.text}
          <svg class="w-4 h-4 md:w-5 md:h-5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>

      <!-- Authority Banner -->
      <div class="w-full flex flex-col gap-3 mt-auto pb-2">
        <p class="text-center text-xs font-semibold tracking-widest text-[#9CA3AF] uppercase">Trusted by industry leaders</p>
        <div class="w-full py-4 overflow-hidden mask-edges marquee-container">
          <div class="flex w-[200%] animate-scroll items-center">
            <div class="flex w-1/2 justify-around items-center px-4 gap-12 sm:gap-20">
              <img src="https://placehold.co/200x80/transparent/white?text=Logo+1" alt="Client 1" class="logo-image" width="200" height="80" loading="lazy" />
              <img src="https://placehold.co/200x80/transparent/white?text=Logo+2" alt="Client 2" class="logo-image" width="200" height="80" loading="lazy" />
              <img src="https://placehold.co/200x80/transparent/white?text=Logo+3" alt="Client 3" class="logo-image" width="200" height="80" loading="lazy" />
              <img src="https://placehold.co/200x80/transparent/white?text=Logo+4" alt="Client 4" class="logo-image" width="200" height="80" loading="lazy" />
              <img src="https://placehold.co/200x80/transparent/white?text=Logo+5" alt="Client 5" class="logo-image" width="200" height="80" loading="lazy" />
              <img src="https://placehold.co/200x80/transparent/white?text=Logo+6" alt="Client 6" class="logo-image" width="200" height="80" loading="lazy" />
            </div>
            <div class="flex w-1/2 justify-around items-center px-4 gap-12 sm:gap-20">
              <img src="https://placehold.co/200x80/transparent/white?text=Logo+1" alt="Client 1" class="logo-image" width="200" height="80" loading="lazy" />
              <img src="https://placehold.co/200x80/transparent/white?text=Logo+2" alt="Client 2" class="logo-image" width="200" height="80" loading="lazy" />
              <img src="https://placehold.co/200x80/transparent/white?text=Logo+3" alt="Client 3" class="logo-image" width="200" height="80" loading="lazy" />
              <img src="https://placehold.co/200x80/transparent/white?text=Logo+4" alt="Client 4" class="logo-image" width="200" height="80" loading="lazy" />
              <img src="https://placehold.co/200x80/transparent/white?text=Logo+5" alt="Client 5" class="logo-image" width="200" height="80" loading="lazy" />
              <img src="https://placehold.co/200x80/transparent/white?text=Logo+6" alt="Client 6" class="logo-image" width="200" height="80" loading="lazy" />
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
