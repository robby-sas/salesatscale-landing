---
import { siteConfig } from "../../../site.config";
const { cta } = siteConfig;
---

<section class="relative h-screen bg-base pt-20 pb-6 overflow-hidden">
  <!-- EXECUTIVE BACKGROUND -->
  <div class="absolute inset-0 w-full h-full bg-base z-0 overflow-hidden pointer-events-none">
    <!-- Layer 1: Ambient Animated Glows -->
    <div class="absolute inset-0 overflow-hidden z-0">
      <div class="absolute -top-[20%] -right-[10%] w-[60%] h-[60%] rounded-full bg-[#003be0] blur-[120px] animate-blob"></div>
      <div class="absolute top-[50%] -left-[20%] w-[50%] h-[50%] rounded-full bg-[#003be0] blur-[140px] animate-blob-delayed"></div>
      <div class="absolute top-[20%] left-[20%] w-[40%] h-[40%] rounded-full bg-[#1E2A45] opacity-30 blur-[100px]"></div>
    </div>

    <!-- Layer 2: Executive Grid -->
    <div class="absolute inset-0 w-full h-full opacity-30 z-0 mask-vignette">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="executive-grid" width="48" height="48" patternUnits="userSpaceOnUse">
            <path d="M 48 0 L 0 0 0 48" fill="none" stroke="#1E2A45" stroke-width="0.5"/>
            <path d="M 24 22 L 24 26 M 22 24 L 26 24" fill="none" stroke="#003be0" stroke-width="1" opacity="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#executive-grid)" />
      </svg>
    </div>

    <!-- Layer 3: Top Border Accent Line -->
    <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#003be0] to-transparent opacity-50 z-10"></div>

    <!-- Layer 4: Cinematic Noise/Grain Overlay -->
    <div class="bg-noise z-10"></div>

    <!-- Layer 5: Dark Fade to next section -->
    <div class="absolute bottom-0 left-0 w-full h-48 bg-gradient-to-t from-base to-transparent z-10"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 h-full">
    <div class="flex flex-col items-center justify-start pt-14 md:pt-16 h-full gap-4 md:gap-5">
      <!-- Headline -->
      <div class="scroll-animate text-center w-full max-w-4xl">
        <h1 class="font-chivo font-black text-heading leading-[0.92] tracking-[-0.035em] text-5xl md:text-6xl lg:text-7xl mb-2">
          We Close. <span class="text-blue">You Scale.</span>
        </h1>
        <p class="font-jakarta font-normal text-body text-sm md:text-base tracking-normal max-w-xl mx-auto leading-relaxed">
          We recruit, train, and manage your sales team on a performance-only basis.
        </p>
      </div>

      <!-- Video / VSL -->
      <div class="scroll-animate w-full max-w-3xl flex-shrink-0">
        <div class="relative rounded-2xl overflow-hidden bg-card border border-card-border aspect-video shadow-card">
          <!-- Subtle blue glow behind video -->
          <div class="absolute -inset-4 bg-blue-glow rounded-3xl blur-2xl -z-10"></div>
          <img
            src="https://placehold.co/960x540/1E293B/003be0?text=VSL+Video"
            alt="SalesAtScale.io overview video"
            class="w-full h-full object-cover"
            width="960"
            height="540"
            loading="eager"
          />
          <div class="absolute inset-0 flex items-center justify-center">
            <button class="w-16 h-16 md:w-20 md:h-20 bg-blue rounded-full flex items-center justify-center shadow-btn-glow hover:bg-blue-hover hover:scale-105 transition-all duration-300" aria-label="Play video">
              <svg class="w-6 h-6 md:w-8 md:h-8 text-heading ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="scroll-animate">
        <a href={cta.primary.url} class="group inline-flex items-center gap-2 bg-blue hover:bg-blue-hover text-heading font-chivo font-bold text-sm md:text-base tracking-[0.08em] uppercase px-12 md:px-16 py-4 md:py-5 rounded-full transition-all duration-300 shadow-btn-glow hover:shadow-btn-glow-hover hover:scale-[1.02]">
          {cta.primary.text}
          <svg class="w-4 h-4 md:w-5 md:h-5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
