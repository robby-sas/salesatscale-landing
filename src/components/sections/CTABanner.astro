---
import { siteConfig } from "../../../site.config";
const { cta } = siteConfig;
---

<section class="bg-[#050505] py-12 px-6">
  <div class="scroll-animate relative w-full max-w-5xl mx-auto rounded-none overflow-hidden flex flex-col md:flex-row items-center p-8 md:p-16" style="background:#0A0A0A; border:1px solid #1F2937;">

    <!-- Abstract Background Layer -->
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
      <!-- Gradient mask for text readability -->
      <div class="absolute inset-0 z-10" style="background: linear-gradient(to right, #0A0A0A, rgba(10,10,10,0.9), transparent);"></div>

      <!-- Floating UI: Revenue Chart -->
      <div class="absolute right-[-2%] top-[10%] w-72 rounded-none p-5 cta-float-slow z-0 opacity-80" style="background:rgba(10,10,10,0.8); border:1px solid #1F2937; transform:rotate(12deg);">
        <div class="flex justify-between items-center mb-4">
          <span class="font-chivo text-xs font-semibold uppercase tracking-wider" style="color:#9CA3AF;">Gross Volume</span>
          <span class="font-chivo text-xs font-bold px-2 py-1" style="color:#10B981; background:rgba(16,185,129,0.1);">+24.5%</span>
        </div>
        <div class="font-chivo font-black text-2xl mb-2" style="color:#F8FAFC;">$154,290.00</div>
        <svg class="w-full h-12" viewBox="0 0 100 30" fill="none" stroke="#10B981" stroke-width="2">
          <path d="M0 25 Q 10 25, 20 15 T 40 20 T 60 10 T 80 15 T 100 2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M0 25 Q 10 25, 20 15 T 40 20 T 60 10 T 80 15 T 100 2 L 100 30 L 0 30 Z" fill="url(#cta-grad)" stroke="none" opacity="0.2"/>
          <defs>
            <linearGradient id="cta-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#10B981" />
              <stop offset="100%" stop-color="transparent" />
            </linearGradient>
          </defs>
        </svg>
      </div>

      <!-- Floating UI: Payment Notification -->
      <div class="absolute right-[15%] bottom-[15%] w-64 rounded-none p-4 cta-float-delayed z-0 opacity-70" style="background:rgba(10,10,10,0.8); border:1px solid #1F2937; transform:rotate(-5deg);">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background:rgba(0,59,224,0.15); border:1px solid rgba(0,59,224,0.3);">
            <svg class="w-5 h-5 text-[#003BE0]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="flex flex-col">
            <span class="font-chivo font-bold text-sm" style="color:#F8FAFC;">Payment Received</span>
            <span class="font-chivo font-black text-lg" style="color:#10B981;">+$9,800.00</span>
          </div>
        </div>
      </div>

      <!-- Floating UI: Mini Bar Chart -->
      <div class="absolute right-[25%] top-[50%] w-48 rounded-none p-4 cta-float-fast z-0 opacity-50" style="background:rgba(10,10,10,0.6); border:1px solid #1F2937; transform:rotate(8deg);">
        <div class="flex items-end justify-between h-16 gap-2">
          <div class="w-full rounded-none h-[40%]" style="background:rgba(0,59,224,0.3);"></div>
          <div class="w-full rounded-none h-[60%]" style="background:rgba(0,59,224,0.5);"></div>
          <div class="w-full rounded-none h-[85%]" style="background:rgba(0,59,224,0.7);"></div>
          <div class="w-full rounded-none h-[100%] bg-[#003BE0]"></div>
        </div>
        <div class="mt-2 font-chivo text-[10px] font-bold uppercase tracking-widest text-center" style="color:#9CA3AF;">Close Rate</div>
      </div>
    </div>

    <!-- Content -->
    <div class="relative z-20 w-full md:w-[65%] flex flex-col items-start text-left">
      <h2 class="font-chivo font-black text-4xl md:text-5xl lg:text-[56px] leading-[1.05] tracking-tight mb-6" style="color:#F8FAFC;">
        Ready to Transform <br class="hidden sm:block" />Your Sales Game?
      </h2>
      <p class="font-chivo font-medium text-[18px] md:text-[20px] leading-relaxed mb-10 max-w-xl" style="color:#9CA3AF;">
        Stop settling for ordinary and dive into extraordinary with SalesAtScale. Click below and let's make your sales strategy the success story you know it can be.
      </p>
      <a href={cta.primary.url} class="group inline-flex items-center gap-2 px-10 py-4 font-chivo font-black text-lg rounded-full transition-colors duration-300 bg-white text-[#050505] hover:bg-[#F8FAFC]">
        Get Started!
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>

<style>
  @keyframes cta-float {
    0%, 100% { transform: translateY(0) rotate(var(--r)); }
    50% { transform: translateY(-15px) rotate(var(--r)); }
  }
  .cta-float-slow { --r: 12deg; animation: cta-float 8s ease-in-out infinite; }
  .cta-float-delayed { --r: -5deg; animation: cta-float 10s ease-in-out infinite 2s; }
  .cta-float-fast { --r: 8deg; animation: cta-float 6s ease-in-out infinite 1s; }
</style>
