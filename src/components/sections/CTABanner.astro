---
import { siteConfig } from "../../../site.config";
const { cta } = siteConfig;
---

<section class="bg-[#003BE0] py-24 px-6">
  <div class="scroll-animate max-w-4xl mx-auto text-center">
    <h2 class="font-chivo font-black text-white text-4xl md:text-5xl lg:text-[56px] leading-[1.05] tracking-tight mb-6">
      Ready to Transform <br class="hidden sm:block" />Your Sales Game?
    </h2>
    <p class="font-chivo font-medium text-white/80 text-[18px] md:text-[20px] leading-relaxed mb-10 max-w-xl mx-auto">
      Stop settling for ordinary and dive into extraordinary with SalesAtScale. Click below and let's make your sales strategy the success story you know it can be.
    </p>
    <a href={cta.primary.url} class="group inline-flex items-center gap-2 px-10 py-4 font-chivo font-black text-lg rounded-full transition-colors duration-300 bg-white text-[#050505] hover:bg-[#F8FAFC]">
      Get Started!
      <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>
