---
---

<div class="w-full h-px bg-[#1F2937]"></div>
<section class="bg-[#050505] py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="scroll-animate text-center mb-16">
      <span class="font-jakarta font-semibold text-xs tracking-[0.18em] uppercase text-[#003BE0] mb-4 block">Who We Help</span>
      <h2 class="font-chivo font-black text-[#F8FAFC] text-4xl md:text-5xl tracking-[-0.03em] leading-[1]">
        We Help High Ticket Product<br/>&amp; Service Businesses Scale
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto items-stretch">

      <!-- Card 1: Info Products -->
      <div class="scroll-animate group relative bg-[#0A0A0A] rounded-none overflow-hidden border border-[#1F2937] flex flex-col transition-colors duration-300 hover:border-[#003BE0]">
        <div class="relative z-20 p-8 flex flex-col min-h-[420px]">
          <h3 class="font-chivo font-black text-[#F8FAFC] text-[34px] tracking-tight leading-[1.05] mb-5 uppercase">Info Products</h3>
          <p class="font-jakarta font-medium text-[#9CA3AF] text-[17px] leading-relaxed">
            Scale course creators and coaching businesses to million-dollar months. We've worked with the biggest names in the industry, year after year, getting massive results.
          </p>
        </div>
      </div>

      <!-- Card 2: Masterminds -->
      <div class="scroll-animate group relative bg-[#0A0A0A] rounded-none overflow-hidden border border-[#1F2937] flex flex-col transition-colors duration-300 hover:border-[#003BE0]">
        <div class="relative z-20 p-8 flex flex-col min-h-[420px]">
          <h3 class="font-chivo font-black text-[#F8FAFC] text-[34px] tracking-tight leading-[1.05] mb-5 uppercase">Masterminds</h3>
          <p class="font-jakarta font-medium text-[#9CA3AF] text-[17px] leading-relaxed">
            We build and manage high-performing sales teams for masterminds, group coaching programs, and high-ticket communities looking to scale enrollment. We handle the volume so you can focus on the impact.
          </p>
        </div>
      </div>

      <!-- Card 3: Service Providers -->
      <div class="scroll-animate group relative bg-[#0A0A0A] rounded-none overflow-hidden border border-[#1F2937] flex flex-col transition-colors duration-300 hover:border-[#003BE0]">
        <div class="relative z-20 p-8 flex flex-col min-h-[420px]">
          <h3 class="font-chivo font-black text-[#F8FAFC] text-[34px] tracking-tight leading-[1.05] mb-5 uppercase">Service Providers</h3>
          <p class="font-jakarta font-medium text-[#9CA3AF] text-[17px] leading-relaxed">
            From wealth advisors and insurance providers to health & wellness companies, trading firms, and DFY businesses — we generate consistent qualified leads at scale.
          </p>
        </div>
      </div>

    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <a href="/apply/" class="group inline-flex items-center gap-2 bg-[#003BE0] hover:bg-[#0044FF] text-white font-chivo font-bold text-sm md:text-base tracking-[0.08em] uppercase px-12 md:px-16 py-4 md:py-5 rounded-full transition-colors duration-300">
        APPLY NOW
        <svg class="w-4 h-4 md:w-5 md:h-5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
  </div>
</section>
<div class="w-full h-px bg-[#1F2937]"></div>
