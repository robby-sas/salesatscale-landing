---
---

<section class="bg-surface py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="scroll-animate text-center mb-16">
      <span class="font-jakarta font-semibold text-xs tracking-[0.18em] uppercase text-blue mb-4 block">Who We Help</span>
      <h2 class="font-chivo font-black text-heading text-4xl md:text-5xl tracking-[-0.03em] leading-[1]">
        We Help High Ticket Product<br/>&amp; Service Businesses Scale
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto items-stretch">

      <!-- Card 1: Info Products -->
      <div class="scroll-animate group relative bg-card rounded-2xl overflow-hidden border border-card-border shadow-card hover:border-blue/50 transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_20px_80px_rgba(0,0,0,0.7)]">
        <div class="absolute top-0 left-0 w-full h-1.5 bg-blue shadow-[0_0_15px_rgba(0,59,224,0.5)] opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-20"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-blue/10 to-transparent opacity-60"></div>
        <div class="relative p-8 flex flex-col min-h-[420px]">
          <h3 class="font-chivo font-black text-heading text-[34px] tracking-tight leading-[1.05] mb-5 uppercase drop-shadow-md">Info Products</h3>
          <p class="font-jakarta font-medium text-body text-[17px] leading-relaxed">
            Scale course creators and coaching businesses to million-dollar months. We've worked with the biggest names in the industry, year after year, getting massive results.
          </p>
        </div>
      </div>

      <!-- Card 2: Masterminds (Custom SVG Card) -->
      <div class="scroll-animate group relative bg-card rounded-2xl overflow-hidden border border-card-border flex flex-col transition-all duration-500 hover:border-blue hover:shadow-[0_20px_80px_rgba(0,0,0,0.7)] hover:-translate-y-1">
        <div class="absolute top-0 left-0 w-full h-1.5 bg-blue shadow-[0_0_15px_rgba(0,59,224,0.5)] opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-20"></div>

        <!-- Technical Infrastructure SVG -->
        <div class="absolute inset-0 z-0 opacity-40 group-hover:opacity-65 transition-opacity duration-500 pointer-events-none">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_20%,#1E293B_95%)] z-10 opacity-80"></div>
          <svg viewBox="0 0 400 500" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
            <defs>
              <pattern id="heavyGrid" width="50" height="50" patternUnits="userSpaceOnUse">
                <path d="M 50 0 L 0 0 0 50" fill="none" stroke="#94A3B8" stroke-width="0.6" opacity="0.4"/>
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#heavyGrid)" />
            <g class="system-float">
              <g stroke="#94A3B8" stroke-width="1.2" opacity="0.7">
                <path d="M200 160 L50 40 H10" stroke-dasharray="6 3" />
                <path d="M200 160 L350 40 H390" stroke-dasharray="6 3" />
                <path d="M200 160 L80 340 V400" stroke-dasharray="6 3" />
                <path d="M200 160 L320 340 V400" stroke-dasharray="6 3" />
                <path d="M200 160 H380 V220" stroke-dasharray="6 3" />
                <path d="M200 160 L50 40 H10" class="animate-flow" stroke="#003BE0" stroke-width="3" />
                <path d="M200 160 L320 340 V400" class="animate-flow" stroke="#003BE0" stroke-width="3" style="animation-delay: 0.7s" />
                <path d="M200 160 H380 V220" class="animate-flow" stroke="#003BE0" stroke-width="3" style="animation-delay: 1.2s" />
              </g>
              <circle cx="10" cy="40" r="6" fill="#003BE0" class="node-glow" />
              <circle cx="390" cy="40" r="6" fill="#94A3B8" />
              <circle cx="380" cy="220" r="5" fill="#003BE0" class="node-glow" />
              <g class="hub-core">
                <path d="M120 160 H280 M200 80 V240" stroke="#003BE0" stroke-width="1" opacity="0.5" />
                <circle cx="200" cy="160" r="55" stroke="#003BE0" stroke-width="2" stroke-dasharray="12 6" />
                <rect x="185" y="145" width="30" height="30" fill="#003BE0" />
                <rect x="192" y="152" width="16" height="16" fill="#F8FAFC" />
              </g>
            </g>
            <g opacity="0.8">
              <rect x="20" y="20" width="135" height="18" fill="rgba(0, 59, 224, 0.1)" stroke="#003BE0" stroke-width="0.5" />
              <text x="28" y="32" fill="#F8FAFC" font-family="monospace" font-size="9" font-weight="bold">SYSTEM_SCALING_ACTIVE</text>
            </g>
          </svg>
        </div>

        <div class="relative z-20 p-8 flex flex-col min-h-[420px]">
          <h3 class="font-chivo font-black text-heading text-[34px] tracking-tight leading-[1.05] mb-5 uppercase drop-shadow-md">Masterminds</h3>
          <p class="font-jakarta font-medium text-body text-[17px] leading-relaxed">
            We build and manage high-performing sales teams for masterminds, group coaching programs, and high-ticket communities looking to scale enrollment. We handle the volume so you can focus on the impact.
          </p>
        </div>
      </div>

      <!-- Card 3: Service Providers -->
      <div class="scroll-animate group relative bg-card rounded-2xl overflow-hidden border border-card-border shadow-card hover:border-blue/50 transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_20px_80px_rgba(0,0,0,0.7)]">
        <div class="absolute top-0 left-0 w-full h-1.5 bg-blue shadow-[0_0_15px_rgba(0,59,224,0.5)] opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-20"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-blue-deep/15 to-transparent opacity-60"></div>
        <div class="relative p-8 flex flex-col min-h-[420px]">
          <h3 class="font-chivo font-black text-heading text-[34px] tracking-tight leading-[1.05] mb-5 uppercase drop-shadow-md">Service Providers</h3>
          <p class="font-jakarta font-medium text-body text-[17px] leading-relaxed">
            From wealth advisors and insurance providers to health & wellness companies, trading firms, and DFY businesses — we generate consistent qualified leads at scale.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes flow {
    from { stroke-dashoffset: 80; }
    to { stroke-dashoffset: 0; }
  }
  .animate-flow {
    stroke-dasharray: 10 20;
    animation: flow 1.5s linear infinite;
  }
  @keyframes hub-glow {
    0%, 100% { filter: drop-shadow(0 0 10px rgba(0, 59, 224, 0.7)); transform: scale(1) rotate(45deg); }
    50% { filter: drop-shadow(0 0 30px rgba(0, 59, 224, 1)); transform: scale(1.12) rotate(45deg); }
  }
  .hub-core {
    animation: hub-glow 3s infinite ease-in-out;
    transform-origin: 200px 160px;
  }
  @keyframes float-system {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
  }
  .system-float {
    animation: float-system 8s infinite ease-in-out;
  }
  .node-glow {
    filter: drop-shadow(0 0 8px rgba(0, 59, 224, 0.9));
  }
</style>
